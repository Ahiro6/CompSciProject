import keyboard
import stddraw
import time

from player import Player
from swarm import Swarm


class Game:

    def __init__(self, player):

        self.player = player
        self.game_on = False
        
        self.swarms = []

    def game_keys(self):

        if keyboard.is_pressed('a'):
            self.on_a_pressed()
        if keyboard.is_pressed('d'):
            self.on_d_pressed()
        if keyboard.is_pressed('space'):
            self.on_space_pressed()
        if keyboard.is_pressed('k'):
            self.on_k_pressed()
        if keyboard.is_pressed('l'):
            self.on_l_pressed()
        if keyboard.is_pressed('esc'):
            self.game_quit()
            
        keyboard.hook(self.on_released)

    def home_keys(self):
        if keyboard.is_pressed('space'):
            self.game_start()

    
    def home(self):
        
        self.home_keys()

        stddraw.clear(stddraw.GRAY)

        stddraw.setFontFamily('Verdana')
        stddraw.setFontSize(24)
        stddraw.text(0.5, 0.9, 'Welcome to the Game!')
        
        stddraw.setFontSize(20)
        stddraw.text(0.5, 0.8, 'Shoot Aliens to Win!')

        stddraw.setFontSize(16)
        stddraw.text(0.5, 0.6, 'Controls')
        
        stddraw.text(0.5, 0.5, 'Move: [A] - left | [D] - right')
        stddraw.text(0.5, 0.4, 'Rotate: [K] - left | [L] - right')
        stddraw.text(0.5, 0.3, 'Shoot: [Space]')

        stddraw.setFontSize(20)
        stddraw.text(0.5, 0.1, 'Press space to start')

        
    def game(self):
        self.game_keys()

        stddraw.clear(stddraw.BOOK_LIGHT_BLUE)
        
        self.player.draw()

        for swarm in self.swarms:
            swarm.draw()
            game_over = swarm.reach_end()

            if game_over:
                self.game_quit(game_over=True)
                return True
        return False


    def game_over_display(self):

        stddraw.setPenColor(stddraw.RED)
        stddraw.filledRectangle(0.5, 0.5, 0.375, 0.125)
        
        stddraw.setPenColor(stddraw.DARK_GRAY)
        stddraw.setFontSize(30)
        stddraw.text(0.5, 0.5, 'GAME OVER')
    
    def game_start(self):
        self.game_on = True

        swarm = Swarm(30, 0.05, 0.005, 0.005, 10, 10)
        swarm.move()

        self.swarms.append(swarm)

    def game_quit(self, game_over=False):
        self.game_on = False

        self.swarms = []
        self.player.reset()

        if game_over:
            self.game_over_display()


    def start(self):
        live = True

        while live:
           
            if self.game_on:
                game_over = self.game()

                if game_over:
                    pass
                    #time.sleep(1)
            else:
                self.home()

            stddraw.show(100)

    def on_space_pressed(self):
        self.player.attack()

    def on_a_pressed(self):
        self.player.move("L")

    def on_d_pressed(self):
        self.player.move("R")

    def on_k_pressed(self):
        self.player.turn(0.2)
        
    def on_l_pressed(self):
        self.player.turn(-0.2)

    def on_released(self, event):
        if event.event_type == keyboard.KEY_UP:
            self.player.stop()
